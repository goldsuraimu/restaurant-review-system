generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique
  username     String   @unique
  realName     String?  
  nickname     String?   
  gender       String?
  birthday     String?
  phone        String?
  address      String?
  email        String   @unique
  passwordHash String   
  role         String   @default("user")  
  createdAt    DateTime @default(now())   
  updatedAt    DateTime @updatedAt  

  restaurants   Restaurant[]
  restaurantDrafts  RestaurantDraft[]
  
  refreshTokens RefreshToken[]
  reviews Review[]

  newRestaurants   Restaurant[]      @relation("NewUserToRestaurant")
  newDrafts        RestaurantDraft[] @relation("NewUserToDraft")
  newTokens        RefreshToken[]    @relation("NewUserToToken")
  newReviews       Review[]          @relation("NewUserToReview")
}

model Restaurant {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique

  ownerUuid    String   
  owner        User     @relation(fields: [ownerUuid], references: [uuid], onDelete: Cascade)

  userId       Int?   
  newOwner     User?    @relation("NewUserToRestaurant", fields: [userId], references: [id])

  name         String
  nameEn       String?  
  category     String

  description  String?
  phone        String?
  location     String

  rating       Float?
  ratingCount  Int      @default(0)   
  reviewCount  Int      @default(0)   
  
  ratingSum    Int      @default(0)   

  createdAt    DateTime @default(now())   
  updatedAt    DateTime @updatedAt   

  images       RestaurantImage[]
  reviews      Review[]

  newImages    RestaurantImage[] @relation("NewResToImage")
  newReviews   Review[]          @relation("NewResToReview")
} 

model RestaurantDraft {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique

  ownerUuid      String
  owner          User     @relation(fields: [ownerUuid], references: [uuid], onDelete: Cascade)

  userId         Int?
  newOwner       User?    @relation("NewUserToDraft", fields: [userId], references: [id])


  restaurantUuid String  @unique

  name           String
  nameEn         String?
  category       String

  description    String?
  phone          String?
  location       String

  status         String   @default("PENDING")  // PENDING | REJECTED

  reviewNote     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submittedAt    DateTime
  rejectedAt     DateTime?

  images         RestaurantDraftImage[]

  newImages      RestaurantDraftImage[] @relation("NewDraftToImage")
}

model RestaurantImage {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique

  restaurantUuid String?   
  restaurant     Restaurant?  @relation(fields: [restaurantUuid], references: [uuid], onDelete: Cascade)

  restaurantId   Int?
  newRestaurant  Restaurant? @relation("NewResToImage", fields: [restaurantId], references: [id])


  type           String
  url            String
  publicId       String
  sortOrder      Int      @default(0)  

  createdAt      DateTime @default(now())   
}

model RestaurantDraftImage {
  id                   Int      @id @default(autoincrement())

  uuid                 String   @unique

  restaurantDraftUuid  String

  restaurantDraft      RestaurantDraft   @relation(fields: [restaurantDraftUuid], references: [uuid], onDelete: Cascade)

  restaurantDraftId   Int?
  newRestaurantDraft  RestaurantDraft? @relation("NewDraftToImage", fields: [restaurantDraftId], references: [id])


  type                 String
  url                  String

  sourceType           String   @default("DRAFT_UPLOAD")  //  DRAFT_UPLOAD |  PUBLISHED

  publicId             String

  sortOrder            Int      @default(0)

  createdAt            DateTime @default(now())
}

model Review {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique

  restaurantUuid  String  
  restaurant      Restaurant @relation(fields: [restaurantUuid], references: [uuid], onDelete: Cascade)

  userUuid        String  
  user            User     @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  restaurantId   Int?  
  newRestaurant  Restaurant? @relation("NewResToReview", fields: [restaurantId], references: [id])
  userId         Int?  
  newUser        User?       @relation("NewUserToReview", fields: [userId], references: [id])


  rating          Int
  content         String?

  createdAt       DateTime @default(now())   
  updatedAt       DateTime @updatedAt   

  images          ReviewImage[]
  reply           ReviewReply? @relation("ReviewToReply")

  newImages      ReviewImage[] @relation("NewReviewToImage")
  newReply       ReviewReply?  @relation("NewReplyToReview")

  @@unique([restaurantUuid, userUuid])
}

model ReviewImage {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique

  reviewUuid  String  
  review      Review   @relation(fields: [reviewUuid], references: [uuid], onDelete: Cascade)

  reviewId    Int?  
  newReview   Review?  @relation("NewReviewToImage", fields: [reviewId], references: [id])


  url         String?
  publicId    String?

  createdAt   DateTime @default(now())    
}

model ReviewReply {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique
  reviewUuid String  @unique

  reviewId   Int?     @unique  
  newReview  Review?  @relation("NewReplyToReview", fields: [reviewId], references: [id])


  content   String
  createdAt DateTime @default(now())   
  updatedAt DateTime @updatedAt   

  review Review @relation("ReviewToReply", fields: [reviewUuid], references: [uuid], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id
  userUuid  String  

  userId    Int?  
  newUser   User?    @relation("NewUserToToken", fields: [userId], references: [id])


  expiresAt Int     
  revokedAt Int?    

  user User @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
}
