generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique
  username     String   @unique
  realName     String?  
  nickname     String?   
  gender       String?
  birthday     String?
  phone        String?
  address      String?
  email        String   @unique
  passwordHash String   
  role         String   @default("user")  
  createdAt    DateTime @default(now())   
  updatedAt    DateTime @updatedAt  

  restaurants   Restaurant[]
  restaurantDrafts  RestaurantDraft[]
  
  refreshTokens RefreshToken[]
  reviews Review[]
}

model Restaurant {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique

  userId       Int   
  owner        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  nameEn       String?  
  category     String

  description  String?
  phone        String?
  location     String

  rating       Float?
  ratingCount  Int      @default(0)   
  reviewCount  Int      @default(0)   
  
  ratingSum    Int      @default(0)   

  createdAt    DateTime @default(now())   
  updatedAt    DateTime @updatedAt   

  images       RestaurantImage[]
  reviews      Review[]
  stats RestaurantStats?
} 

model RestaurantStats {
  id           Int @id @default(autoincrement())

  restaurantId Int @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  rating       Float?
  ratingCount  Int @default(0)
  reviewCount  Int @default(0)
  ratingSum    Int @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RestaurantDraft {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique

  userId         Int
  owner          User   @relation(fields: [userId], references: [id], onDelete: Cascade)


  restaurantUuid String  @unique

  name           String
  nameEn         String?
  category       String

  description    String?
  phone          String?
  location       String

  status         String   @default("PENDING")  // PENDING | REJECTED

  reviewNote     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submittedAt    DateTime
  rejectedAt     DateTime?

  images         RestaurantDraftImage[]
}

model RestaurantImage {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique

  restaurantId   Int
  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)


  type           String
  url            String
  publicId       String
  sortOrder      Int      @default(0)  

  createdAt      DateTime @default(now())   
}

model RestaurantDraftImage {
  id                   Int      @id @default(autoincrement())

  uuid                 String   @unique

  restaurantDraftId   Int
  restaurantDraft  RestaurantDraft @relation(fields: [restaurantDraftId], references: [id], onDelete: Cascade)


  type                 String
  url                  String

  sourceType           String   @default("DRAFT_UPLOAD")  //  DRAFT_UPLOAD |  PUBLISHED

  publicId             String

  sortOrder            Int      @default(0)

  createdAt            DateTime @default(now())
}

model Review {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique

  restaurantId   Int  
  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId         Int  
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)


  rating          Int
  content         String?

  createdAt       DateTime @default(now())   
  updatedAt       DateTime @updatedAt   

  images          ReviewImage[]
  reply           ReviewReply? 

  @@unique([restaurantId, userId])
}

model ReviewImage {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique

  reviewId    Int  
  review   Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)


  url         String?
  publicId    String?

  createdAt   DateTime @default(now())    
}

model ReviewReply {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique

  reviewId   Int     @unique  
  review  Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)


  content   String
  createdAt DateTime @default(now())   
  updatedAt DateTime @updatedAt   
}

model RefreshToken {
  id        String   @id

  userId    Int  
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt Int     
  revokedAt Int?    
}
