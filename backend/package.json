{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "db:dev": "dotenv -e .env.development -- prisma migrate dev",
    "db:deploy": "dotenv -e .env.production -- prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push:dev": "dotenv -e .env.development -- prisma db push",
    "db:push:prod": "dotenv -e .env.production -- prisma db push",
    "seed:dev": "dotenv -e .env.development -- prisma db seed",
    "seed:prod": "dotenv -e .env.production -- prisma db seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "streamifier": "^0.1.1",
    "timezone": "^1.0.23",
    "utc": "^0.1.0",
    "uuid": "^11.1.0",
    "validator": "^13.15.26",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.0",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.15.10",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
